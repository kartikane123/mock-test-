rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Helpers for validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.email is string;
    }

    function isValidTest(data) {
      return data.keys().hasAll(['id', 'userId', 'config', 'questions', 'createdAt']) &&
             data.id is string && data.userId == request.auth.uid &&
             data.questions is list && data.questions.size() > 0 &&
             data.createdAt is string;
    }

    function isValidAttempt(data) {
      return data.keys().hasAll(['id', 'userId', 'testId', 'answers', 'timeTakenSeconds', 'score', 'totalQuestions', 'completedAt']) &&
             data.userId == request.auth.uid &&
             data.testId is string &&
             data.score is int &&
             data.totalQuestions is int;
    }

    // Collections
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    match /tests/{testId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTest(incoming());
      allow update: if false; // Tests are usually immutable after gen
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /attempts/{attemptId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAttempt(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['analysis']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
